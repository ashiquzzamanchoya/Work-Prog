{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Task": {
      "title": "Task",
      "description": "A task in the workflow",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "brief": { "type": "string" },
        "category": { "type": "string" },
        "priority": { "type": "string" },
        "status": { "type": "string" },
        "assigneeId": { "type": "string" },
        "reporterId": { "type": "string" },
        "dueDate": { "type": "string" },
        "createdAt": { "type": "string" },
        "progress": { "type": "number" },
        "commentsCount": { "type": "number" },
        "attachmentsCount": { "type": "number" }
      },
      "required": ["id", "title", "status", "reporterId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users collection"
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Tasks collection"
    }
  }
}
